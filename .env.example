# ─── API ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://solvo-backend-production-1612.up.railway.app/api

# ─── Culqi (pasarela de pagos) ────────────────────────────────────────────────
# Obtén tus llaves en https://culqi.com → Dashboard → Desarrollo → Llaves API
NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ─── Sentry (monitoreo de errores) ────────────────────────────────────────────
# Obtén tu DSN en https://sentry.io → Settings → Projects → tu-proyecto → DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# Para subir source maps en CI/CD (opcional — solo build)
SENTRY_ORG=solvope
SENTRY_PROJECT=solvo-web
SENTRY_AUTH_TOKEN=sntrys_xxxx
